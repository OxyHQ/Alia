{
  "name": "@alia-codea/cli",
  "version": "2.0.2",
  "description": "Codea CLI - AI coding assistant for your terminal by OxyAI",
  "main": "dist/index.js",
  "bin": {
    "codea": "./dist/index.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsup src/index.ts --format esm --clean",
    "dev": "bun src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "ai",
    "cli",
    "coding",
    "assistant",
    "terminal",
    "alia",
    "codea"
  ],
  "author": "OxyAI",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^15.0.0",
    "conf": "^15.1.0",
    "ink": "^7.1.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "marked": "^18.0.6",
    "marked-terminal": "^7.3.0",
    "openai": "^6.46.0",
    "ora": "^9.4.1",
    "react": "19.2.0",
    "simple-git": "^3.36.0"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "@types/react": "^19.2.17",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18"
  }
}
