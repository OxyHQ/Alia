# Mastodon Instance Configuration
MASTODON_INSTANCE_URL=https://alia.onl
MASTODON_ACCESS_TOKEN=your_access_token_here

# API Server (your main API server)
API_BASE_URL=http://localhost:3001

# Bot Secret (shared secret for authenticating bot-to-API calls)
MASTODON_BOT_SECRET=your_secure_random_secret_here

# Polling Configuration
NOTIFICATION_POLL_INTERVAL=30000

# Node Environment
NODE_ENV=development
