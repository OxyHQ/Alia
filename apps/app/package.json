{
  "name": "@alia/app",
  "main": "index",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start --clear --tunnel",
    "dev": "expo start --scheme alia",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "generate-sitemap": "bun scripts/generate-sitemap.ts",
    "setup-skia-web": "bun x setup-skia-web public",
    "prebuild": "bun run setup-skia-web && bun run generate-sitemap",
    "build": "bun x expo export --platform web",
    "build:production": "NODE_ENV=production bun x expo export --platform web --clear",
    "build:android": "eas build --platform android",
    "build:ios": "eas build --platform ios"
  },
