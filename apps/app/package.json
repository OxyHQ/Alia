{
  "name": "@alia/app",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start --clear --tunnel",
    "dev": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "generate-sitemap": "tsx scripts/generate-sitemap.ts",
    "prebuild": "npm run generate-sitemap",
    "build": "EXPO_UNSTABLE_TREE_SHAKING=1 EXPO_UNSTABLE_METRO_OPTIMIZE_GRAPH=1 npx expo export --platform web",
    "build:production": "NODE_ENV=production EXPO_UNSTABLE_TREE_SHAKING=1 EXPO_UNSTABLE_METRO_OPTIMIZE_GRAPH=1 npx expo export --platform web --clear",
    "build:android": "eas build --platform android",
    "build:ios": "eas build --platform ios"
  },
  "dependencies": {
    "@ai-sdk/react": "^1.2.12",
    "@expo/html-elements": "^0.13.8",
    "@expo/vector-icons": "^15.0.3",
    "@hugeicons/react-native": "^1.0.11",
    "@lottiefiles/dotlottie-react": "^0.13.5",
    "@oxyhq/services": "^5.21.6",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/hooks": "^100.1.0",
    "@react-navigation/drawer": "^7.5.0",
