    "ai": "^6.0.34",
    "axios": "^1.13.2",
    "babel-preset-expo": "~54.0.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "expo": "~54.0.31",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-device": "~8.0.10",
