# Server
PORT=9091
NODE_ENV=development

# MongoDB (shared cluster, own database: alia-providers-api-{NODE_ENV})
MONGODB_URI=mongodb+srv://...

# Service-to-service auth (shared with main API)
SERVICE_SECRET=your-shared-secret
ALLOWED_SERVICES=alia-api

# Admin access (Bearer token auth via OxyHQ)
OXY_API_URL=https://api.oxy.so
ADMIN_USERNAMES=nate
