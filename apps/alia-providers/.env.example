# Server Configuration
PORT=3002
NODE_ENV=development

# MongoDB (shared with main API)
MONGODB_URI=mongodb://localhost:27017/alia

# Service Authentication
SERVICE_SECRET=your-secret-key-here-min-32-chars-long
ALLOWED_SERVICES=alia-api,alia-dashboard

# CORS Configuration
# Comma-separated list of allowed origins
# Development: http://localhost:5173,http://localhost:3001
# Production: https://providers.alia.onl,https://api.alia.onl
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3001

# Key Encryption (for secure key storage)
ENCRYPTION_KEY=your-32-byte-hex-encryption-key-here

# Monitoring
ENABLE_HEALTH_MONITOR=true
HEALTH_CHECK_INTERVAL_MS=300000

# Rate Limiting Defaults
DEFAULT_RPM=60
DEFAULT_TPM=100000

# Logging
LOG_LEVEL=info

# Provider Keys (fallback - will be migrated to MongoDB)
# These will be automatically migrated to the database on first run
OPENAI_KEYS=
ANTHROPIC_KEYS=
GOOGLE_KEYS=
GROQ_KEYS=
MISTRAL_KEYS=
DEEPSEEK_KEYS=
TOGETHER_KEYS=
CEREBRAS_KEYS=
CLOUDFLARE_KEYS=
OPENROUTER_KEYS=
