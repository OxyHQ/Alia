{
  "name": "@alia/providers",
  "version": "1.0.0",
  "description": "Alia Providers Microservice - Centralized provider management and API key handling",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --outfile=dist/index.js --external:mongoose --external:express",
    "start": "node dist/index.js",
    "migrate:keys": "tsx scripts/migrate-keys.ts",
    "migrate:models": "tsx scripts/migrate-models.ts",
    "seed": "tsx scripts/seed-data.ts"
  },
  "keywords": ["alia", "providers", "api", "microservice"],
  "author": "Alia AI",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^8.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "zod": "^3.22.4",
    "jsonwebtoken": "^9.0.2",
    "@oxyhq/core": "latest"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/cors": "^2.8.17",
    "@types/jsonwebtoken": "^9.0.5",
    "tsx": "^4.7.0",
    "esbuild": "^0.19.11",
    "typescript": "^5.3.3"
  }
}
