# ================================
# DATABASE CONFIGURATION
# ================================
# MongoDB connection string
# Local: mongodb://localhost:27017/alia
# Atlas: mongodb+srv://<username>:<password>@cluster.mongodb.net/alia
MONGODB_URI=mongodb://localhost:27017/alia

# ================================
# API SERVER CONFIGURATION
# ================================
# Port where the API server will run
PORT=3001

# URL of the web application (for CORS)
WEB_URL=http://localhost:3000

# URL of the mobile app (for Telegram bot authentication redirects)
# If not set, will use WEB_URL
APP_URL=http://localhost:3000

# URL of the API server itself (for generating telegram auth links)
# Required for Telegram bot integration
API_BASE_URL=http://localhost:3001

# ================================
# TELEGRAM BOT INTEGRATION
# ================================
# Telegram Bot Token from @BotFather
# Required only if you want to send notifications from the API
# (Optional - the telegram bot worker also uses this, but it's good to have it here too)
# TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Telegram Bot Username (without @)
# Required for Telegram sign-in deep links
# Example: alia_onlbot
TELEGRAM_BOT_USERNAME=alia_onlbot

# ================================
# AUTHENTICATION
# ================================
# Secret key for JWT token generation
# IMPORTANT: Change this to a strong random string in production!
# Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ================================
# INTERNAL PROVIDERS MODULE
# ================================
# Service secret for admin panel authentication (HMAC)
# Generate with: openssl rand -hex 32
SERVICE_SECRET=your-service-secret-min-32-chars-change-this

# ================================
# AWS S3 CONFIGURATION
# ================================
# Required for avatar uploads and file storage
# Instructions:
# 1. Create an S3 bucket in AWS Console
# 2. Create an IAM user with S3 permissions (PutObject, GetObject, DeleteObject)
# 3. Configure bucket policy to allow public read access for uploads folder
# 4. Add credentials below

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_S3_BUCKET=your-s3-bucket-name

# ================================
# AI PROVIDER API KEYS
# ================================
# Add at least one AI provider key to enable chat functionality
# Uncomment the providers you want to use

# Google AI (Gemini)
# Get your key at: https://makersuite.google.com/app/apikey
# GOOGLE_API_KEY=your-google-api-key

# OpenAI (GPT-4, GPT-3.5)
# Get your key at: https://platform.openai.com/api-keys
# OPENAI_API_KEY=your-openai-api-key

# Anthropic (Claude)
# Get your key at: https://console.anthropic.com/
# ANTHROPIC_API_KEY=your-anthropic-api-key

# Groq (Fast inference)
# Get your key at: https://console.groq.com/
# GROQ_API_KEY=your-groq-api-key

# Together AI
# Get your key at: https://api.together.ai/
# TOGETHER_API_KEY=your-together-api-key

# Cerebras (Fast inference)
# Get your key at: https://cloud.cerebras.ai/
# CEREBRAS_API_KEY=your-cerebras-api-key

# ================================
# NOTES
# ================================
# - Copy this file to .env and fill in your actual values
# - Never commit .env to version control
# - Rotate JWT_SECRET regularly in production
# - Use environment-specific .env files for different deployments
