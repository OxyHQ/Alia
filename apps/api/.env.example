# =============================================================================
# Alia API — Runtime environment variables
# =============================================================================
# Copy to `.env` and fill in real values. NEVER commit `.env`.
#
# Legend:
#   [SECRET]   — sensitive value; inject via your secrets manager (AWS Secrets
#                Manager / SSM Parameter Store), never hard-code in manifests.
#   [required] — the server starts without it, but the related feature is
#                disabled or will error when used.
#
# The container BOOTS and listens even if MongoDB / Redis / LiveKit / Stripe
# are unreachable. Readiness (/health/ready) reports not_ready until MongoDB
# connects; liveness (/health/live) always returns 200 while the process runs.
# Provider API keys (OpenAI/Anthropic/etc.) are NOT configured here — they live
# in the alia-gateway service. The API reaches it via GATEWAY_API_URL +
# SERVICE_SECRET.
# =============================================================================

# -----------------------------------------------------------------------------
# CORE SERVER
# -----------------------------------------------------------------------------
# Port the HTTP/WebSocket server listens on (defaults to 3001 if unset).
PORT=3001
# Node environment. Also selects the MongoDB database name: `alia-{NODE_ENV}`.
NODE_ENV=production
# Log level for pino: trace | debug | info | warn | error (default: info in prod).
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# DATABASE — MongoDB (required)
# -----------------------------------------------------------------------------
# Connection string WITHOUT the database name (db name is `alia-{NODE_ENV}`).
# Atlas: mongodb+srv://<user>:<pass>@cluster.mongodb.net/
MONGODB_URI=mongodb://localhost:27017            # [SECRET][required]
# PEM CA certificate for managed MongoDB requiring TLS (optional).
# CA_CERT=                                        # [SECRET]

# -----------------------------------------------------------------------------
# REDIS — task queue, rate limiting, Socket.IO adapter (optional)
# -----------------------------------------------------------------------------
# If unset: BullMQ async tasks run inline, rate limiting fails open.
# Local: redis://localhost:6379   Managed TLS: rediss://user:pass@host:port
# REDIS_URL=redis://localhost:6379                # [SECRET]
# PEM CA certificate for Redis over TLS (falls back to CA_CERT if unset).
# REDIS_CA_CERT=                                  # [SECRET]

# -----------------------------------------------------------------------------
# PUBLIC URLs (CORS, auth redirects, link generation)
# -----------------------------------------------------------------------------
# Web app origin (added to the CORS allow-list).
WEB_URL=https://alia.onl
# Mobile app URL for auth redirects (defaults to WEB_URL).
# APP_URL=https://alia.onl
# Public URL of this API (used to build auth links).
# API_BASE_URL=https://api.alia.onl
# Public URL of this API used by agent browser sessions/tools.
# ALIA_API_URL=https://api.alia.onl

# -----------------------------------------------------------------------------
# AUTHENTICATION & INTERNAL SECRETS
# -----------------------------------------------------------------------------
# OxyHQ identity API base URL (auth/token verification).
OXY_API_URL=https://api.oxy.so
# Shared HMAC secret. Authenticates this API to the alia-gateway and gates the
# internal providers module. Generate: openssl rand -hex 32
SERVICE_SECRET=                                   # [SECRET][required]
# AES-256-GCM key (64-char hex) encrypting stored OAuth tokens.
# Required for OAuth integrations. Generate: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=                             # [SECRET]
# Comma-separated admin usernames for the internal/admin panel (default: nate).
# ADMIN_USERNAMES=nate
# Comma-separated services allowed to call the internal module (default: alia-api).
# ALLOWED_SERVICES=alia-api

# -----------------------------------------------------------------------------
# ALIA GATEWAY (AI provider routing) — required for chat/inference
# -----------------------------------------------------------------------------
# Internal URL of the alia-gateway service. Provider keys live there, not here.
GATEWAY_API_URL=http://gateway:9091

# -----------------------------------------------------------------------------
# OBJECT STORAGE — S3 / DigitalOcean Spaces / compatible (required for uploads)
# -----------------------------------------------------------------------------
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=                                # [SECRET][required]
AWS_SECRET_ACCESS_KEY=                            # [SECRET][required]
AWS_S3_BUCKET=bucket-alia
# Custom S3 endpoint for non-AWS providers (e.g. https://ams3.digitaloceanspaces.com).
# AWS_ENDPOINT_URL=
# Public CDN base URL for stored objects (defaults to the bucket URL).
# AWS_CDN_URL=

# -----------------------------------------------------------------------------
# BILLING — Stripe (optional; billing routes error until set)
# -----------------------------------------------------------------------------
# STRIPE_SECRET_KEY=                              # [SECRET]
# STRIPE_WEBHOOK_SECRET=                          # [SECRET]

# -----------------------------------------------------------------------------
# LIVEKIT — realtime voice/video (optional)
# -----------------------------------------------------------------------------
# LIVEKIT_URL=wss://livekit.oxy.so
# LIVEKIT_INTERNAL_URL=wss://livekit.oxy.so       # defaults to LIVEKIT_URL
# LIVEKIT_API_KEY=                                # [SECRET]
# LIVEKIT_API_SECRET=                             # [SECRET]
# Voice provider key pool flag (grok voice). Managed via gateway in production.
# GROK_API_KEY=                                   # [SECRET]

# -----------------------------------------------------------------------------
# WEB PUSH — browser notifications (optional)
# -----------------------------------------------------------------------------
# Generate a key pair: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=                              # [SECRET]
# VAPID_SUBJECT=mailto:contact@alia.onl

# -----------------------------------------------------------------------------
# INTEGRATIONS SERVICE (MCP tools / channel proxy) — optional
# -----------------------------------------------------------------------------
# INTEGRATIONS_URL=http://integrations:3005
# INTEGRATIONS_SECRET=                            # [SECRET]  openssl rand -hex 32

# -----------------------------------------------------------------------------
# DOCKER HOST (agent container system) — optional
# -----------------------------------------------------------------------------
# DOCKER_HOST_URL=http://docker-host:9090
# DOCKER_HOST_SECRET=                             # [SECRET]  openssl rand -hex 32
# CONTAINER_POOL_SIZE=4
# AGENT_MAX_DURATION_MS=600000
# AUTONOMY_APPROVAL_TIMEOUT_MS=60000
# AUTONOMY_ROLLBACK_WINDOW_MINUTES=30

# -----------------------------------------------------------------------------
# CHANNEL BOTS — per-channel auth (x-channel-bot-secret). Optional.
# Bot tokens/platform creds live in the integrations service; the API only
# needs the matching per-channel secret to validate inbound requests.
# Generate each: openssl rand -hex 32
# -----------------------------------------------------------------------------
# --- Telegram ---
TELEGRAM_BOT_USERNAME=alia_onlbot
# TELEGRAM_BOT_TOKEN=                             # [SECRET]
# TELEGRAM_BOT_SECRET=                            # [SECRET]
# --- Discord ---
# DISCORD_BOT_TOKEN=                              # [SECRET]
# DISCORD_BOT_SECRET=                             # [SECRET]
# DISCORD_APP_ID=
# DISCORD_PUBLIC_KEY=
# --- Slack ---
# SLACK_BOT_TOKEN=                                # [SECRET]
# SLACK_SIGNING_SECRET=                           # [SECRET]
# SLACK_BOT_SECRET=                               # [SECRET]
# --- WhatsApp ---
# WHATSAPP_ACCESS_TOKEN=                          # [SECRET]
# WHATSAPP_APP_SECRET=                            # [SECRET]
# WHATSAPP_BOT_SECRET=                            # [SECRET]
# WHATSAPP_VERIFY_TOKEN=                          # [SECRET]
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_GATEWAY_URL=
# WHATSAPP_GATEWAY_SECRET=                        # [SECRET]
# --- Signal ---
# SIGNAL_CLI_URL=
# SIGNAL_PHONE_NUMBER=
# SIGNAL_BOT_SECRET=                              # [SECRET]

# -----------------------------------------------------------------------------
# GOOGLE OAUTH (account linking) — optional
# -----------------------------------------------------------------------------
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=                     # [SECRET]
