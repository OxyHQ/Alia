{
  "name": "alia-codea",
  "displayName": "Codea by Alia",
  "description": "AI coding assistant powered by Alia",
  "version": "1.0.7",
  "publisher": "oxy",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/OxyHQ/codea-ai-extension"
  },
  "icon": "resources/codea-logo.png",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Machine Learning",
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "AI",
    "assistant",
    "code",
    "chat",
    "alia",
    "codea"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onUri"
  ],
  "main": "./dist/extension.js",
  "browser": "./dist/web/extension.js",
  "contributes": {
    "authentication": [
      {
        "id": "alia",
        "label": "Alia"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codea-sidebar",
          "title": "Codea",
          "icon": "resources/codea-logo.png",
          "when": "codea:doesNotSupportSecondarySidebar"
        }
      ],
      "secondarySidebar": [
        {
          "id": "codea-sidebar-secondary",
          "title": "Codea",
          "icon": "resources/codea-logo.png",
          "when": "!codea:doesNotSupportSecondarySidebar"
        }
      ]
    },
    "views": {
      "codea-sidebar": [
        {
          "type": "webview",
          "id": "codea.chatView",
          "name": "Codea Chat",
          "icon": "resources/codea-logo.png",
          "when": "codea:doesNotSupportSecondarySidebar"
        }
      ],
      "codea-sidebar-secondary": [
        {
          "type": "webview",
          "id": "codea.chatViewSecondary",
          "name": "Codea Chat",
          "icon": "resources/codea-logo.png",
          "when": "!codea:doesNotSupportSecondarySidebar"
        }
      ]
    },
    "commands": [
      {
        "command": "codea.openChat",
        "title": "Open Codea Chat",
        "icon": {
          "light": "resources/codea-logo.png",
          "dark": "resources/codea-logo.png"
        }
      },
      {
        "command": "codea.newConversation",
        "title": "New Conversation",
        "icon": "$(add)"
      },
      {
        "command": "codea.clearConversation",
        "title": "Clear Conversation",
        "icon": "$(clear-all)"
      },
      {
        "command": "codea.openWalkthrough",
        "title": "Codea: Getting Started"
      },
      {
        "command": "codea.signIn",
        "title": "Codea: Sign In"
      },
      {
        "command": "codea.refreshToken",
        "title": "Codea: Refresh Token"
      },
      {
        "command": "codea.toggleStatusMenu",
        "title": "Codea: Toggle Status Menu"
      },
      {
        "command": "codea.git.generateCommitMessage",
        "title": "Codea: Generate Commit Message"
      },
      {
        "command": "codea.git.resolveMergeConflicts",
        "title": "Codea: Resolve Merge Conflicts"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "codea.newConversation",
          "when": "view == codea.chatView || view == codea.chatViewSecondary",
          "group": "navigation"
        },
        {
          "command": "codea.clearConversation",
          "when": "view == codea.chatView || view == codea.chatViewSecondary",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "codea.openChat",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a"
      }
    ],
    "configuration": {
      "title": "Codea by Alia",
      "properties": {
        "codea.apiKey": {
          "type": "string",
          "default": "",
          "description": "(Deprecated: Use 'Codea: Sign In' command instead) Legacy API key (alia_sk_*)",
          "order": 10
        },
        "codea.apiBaseUrl": {
          "type": "string",
          "default": "https://api.alia.onl",
          "description": "Alia API base URL",
          "order": 2
        },
        "codea.model": {
          "type": "string",
          "default": "alia-v1-codea",
          "description": "Model to use for completions (available models are fetched from the API)",
          "order": 3
        },
        "codea.maxTokens": {
          "type": "number",
          "default": 4096,
          "description": "Maximum tokens in response",
          "order": 4
        },
        "codea.temperature": {
          "type": "number",
          "default": 0.7,
          "minimum": 0,
          "maximum": 2,
          "description": "Temperature for response generation",
          "order": 5
        },
        "codea.enableInlineCompletions": {
          "type": "boolean",
          "default": true,
          "description": "Enable inline code completions with AI-powered suggestions",
          "order": 6
        },
        "codea.enableChatParticipant": {
          "type": "boolean",
          "default": true,
          "description": "Enable native chat participant (@codea in Codea Studio Code chat)",
          "order": 7
        }
      }
    },
    "walkthroughs": [
      {
        "id": "codea-walkthrough",
        "title": "Get started with Codea",
        "description": "Learn how to use Codea to write, edit, and understand your code.",
        "steps": [
          {
            "id": "welcome",
            "title": "Your AI coding partner",
            "description": "Codea helps you write, edit, and understand code right in Codea Studio Code.",
            "media": {
              "markdown": "resources/walkthrough/step1.md"
            }
          },
          {
            "id": "open-codea",
            "title": "Open Codea",
            "description": "Click the Codea icon in the sidebar, or press Ctrl+Shift+A (Cmd+Shift+A on Mac) to start a conversation.",
            "media": {
              "markdown": "resources/walkthrough/step2.md"
            },
            "completionEvents": [
              "onCommand:codea.openChat"
            ]
          },
          {
            "id": "chat",
            "title": "Chat with Codea",
            "description": "Type a message and press Enter. Ask questions, request changes, or get help understanding your code.",
            "media": {
              "markdown": "resources/walkthrough/step3.md"
            }
          },
          {
            "id": "sessions",
            "title": "Past conversations",
            "description": "Start a new conversation anytime by clicking New Conversation or pressing Ctrl+N (Cmd+N).",
            "media": {
              "markdown": "resources/walkthrough/step4.md"
            }
          }
        ]
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "npm run build:webview && npm run build:extension && npm run build:browser",
    "build:extension": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
    "build:browser": "esbuild ./src/extension.ts --bundle --outfile=dist/web/extension.js --external:vscode --external:child_process --external:crypto --format=cjs --platform=browser",
    "build:webview": "cd webview-ui && npm run build",
    "watch": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --watch",
    "watch:webview": "cd webview-ui && npm run dev",
    "package": "vsce package --no-dependencies"
  },
  "dependencies": {
    "@oxyhq/core": "^1.7.0",
    "openai": "^6.16.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.22.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.3.0"
  }
}
