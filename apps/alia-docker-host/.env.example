# Shared secret for API authentication
DOCKER_HOST_SECRET=change-me-to-a-random-secret

# DigitalOcean API token for Traefik DNS challenge (Let's Encrypt)
DO_DNS_TOKEN=your-digitalocean-api-token

# Preview domain for exposed container ports
PREVIEW_DOMAIN=preview.alia.onl

# ACME email for Let's Encrypt certificates
ACME_EMAIL=admin@alia.onl

# Port for the management API
PORT=9090
