# ============================================================
# Alia Docker Host - Environment Configuration
# ============================================================
# Copy this file to .env and fill in actual values.

# Shared secret for API <-> Docker host authentication.
# Must match DOCKER_HOST_SECRET in the Alia API .env.
# Generate with: openssl rand -hex 32
DOCKER_HOST_SECRET=change-me-to-a-random-secret

# Preview domain for exposed container ports.
# Requires wildcard DNS (*.preview.alia.onl) pointing to this Droplet.
PREVIEW_DOMAIN=preview.alia.onl

# Email for Let's Encrypt ACME certificate registration.
ACME_EMAIL=admin@alia.onl

# Port for the Docker host management API.
PORT=9090
