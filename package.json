{
  "name": "alia-monorepo",
  "version": "1.0.0",
  "description": "Monorepo para Alia - plataforma de IA con app (web+mobile), API y panel admin",
  "private": true,
  "workspaces": [
    "apps/api",
    "apps/app",
    "apps/alia-chat",
    "apps/alia-canvas",
    "apps/alia-docker-host",
    "apps/integrations",
    "apps/alia-console",
    "apps/alia-gateway-admin",
    "apps/alia-codea",
    "apps/alia-codea/webview-ui",
    "apps/alia-cowork",
    "apps/alia-codea-cli",
    "apps/alia-gateway"
  ],
  "packageManager": "bun@1.3.14",
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "dev:gateway": "bun run --filter @alia/gateway dev",
    "dev:app": "bun run --filter @alia/app dev -- --clear --tunnel",
    "dev:api": "bun run --filter @alia/api dev",
    "dev:admin": "bun run --filter alia-console dev",
    "dev:canvas": "bun run --filter alia-canvas dev",
    "dev:docker-host": "bun run --filter @alia/docker-host dev",
    "dev:integrations": "bun run --filter @alia/integrations dev",
    "dev:gateway-admin": "bun run --filter alia-gateway-admin dev",
    "dev:codea": "bun run --filter alia-codea dev",
    "dev:cowork": "bun run --filter alia-cowork dev",
    "build": "bun run --filter '*' build",
    "build:app": "bun run --filter @alia/app build",
    "build:api": "bun run --filter @alia/api build",
    "build:admin": "bun run --filter alia-console build",
    "build:canvas": "bun run --filter alia-canvas build",
    "build:docker-host": "bun run --filter @alia/docker-host build",
    "build:gateway-admin": "bun run --filter alia-gateway-admin build",
    "build:integrations": "bun run --filter @alia/integrations build",
    "build:gateway": "bun run --filter @alia/gateway build",
    "start:app": "bun run --filter @alia/app start",
    "start:api": "bun run --filter @alia/api start",
    "start:admin": "bun run --filter alia-console start",
    "start:canvas": "bun run --filter alia-canvas start",
    "start:docker-host": "bun run --filter @alia/docker-host start",
    "start:integrations": "bun run --filter @alia/integrations start",
    "start:gateway": "bun run --filter @alia/gateway start",
    "lint": "bun run --filter '*' lint",
    "lint:canvas": "bun run --filter alia-canvas lint",
    "android": "bun run --filter @alia/app android",
    "ios": "bun run --filter @alia/app ios",
    "web": "bun run --filter @alia/app web"
  },
  "keywords": [
    "monorepo",
    "ai",
    "nextjs",
    "expo",
    "api",
    "alia"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "typescript": "^5.9.3"
  },
  "overrides": {
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-svg": "15.15.4",
    "react-native-worklets": "0.8.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo-secure-store": "56.0.4",
    "react-native-screens": "4.25.2",
    "react-native-gesture-handler": "2.31.1",
    "react-native-reanimated": "4.3.1",
    "react-native-keyboard-controller": "1.21.6",
    "expo": "56.0.11",
    "expo-blur": "56.0.3",
    "expo-constants": "56.0.18",
    "expo-file-system": "56.0.8",
    "expo-font": "56.0.6",
    "expo-image": "56.0.11",
    "@react-native-menu/menu": "2.0.0"
  },
  "dependencies": {
    "@oxyhq/auth": "^4.1.1",
    "@oxyhq/bloom": "^0.8.5",
    "@oxyhq/core": "^3.4.13"
  }
}
