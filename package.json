{
  "name": "alia-monorepo",
  "version": "1.0.0",
  "description": "Monorepo para Alia - plataforma de IA con app (web+mobile), API y panel admin",
  "private": true,
  "workspaces": [
    "apps/api",
    "apps/app",
    "apps/alia-canvas",
    "apps/integrations",
    "apps/alia-console",
    "apps/alia-providers-admin",
    "apps/alia-codea",
    "apps/alia-cowork",
    "apps/alia-codea-cli",
    "apps/alia-providers-api"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "dev:providers-api": "npm run dev --workspace=@alia/providers-api",
    "dev:app": "npm run dev --workspace=@alia/app --clear --tunnel",
    "dev:api": "npm run dev --workspace=@alia/api",
    "dev:admin": "npm run dev --workspace=alia-console",
    "dev:canvas": "npm run dev --workspace=alia-canvas",
    "dev:integrations": "npm run dev --workspace=@alia/integrations",
    "dev:providers-admin": "npm run dev --workspace=alia-providers-admin",
    "dev:codea": "npm run dev --workspace=alia-codea",
    "dev:cowork": "npm run dev --workspace=alia-cowork",
    "build": "npm run build --workspaces --if-present",
    "build:app": "npm run build --workspace=@alia/app",
    "build:api": "npm run build --workspace=@alia/api",
    "build:admin": "npm run build --workspace=alia-console",
    "build:canvas": "npm run build --workspace=alia-canvas",
    "build:integrations": "npm run build --workspace=@alia/integrations",
    "start:app": "npm run start --workspace=@alia/app",
    "start:api": "npm run start --workspace=@alia/api",
    "start:admin": "npm run start --workspace=alia-console",
    "start:canvas": "npm run start --workspace=alia-canvas",
    "start:integrations": "npm run start --workspace=@alia/integrations",
    "build:providers-api": "npm run build --workspace=@alia/providers-api",
    "start:providers-api": "npm run start --workspace=@alia/providers-api",
    "lint": "npm run lint --workspaces --if-present",
    "lint:canvas": "npm run lint --workspace=alia-canvas",
    "android": "npm run android --workspace=@alia/app",
    "ios": "npm run ios --workspace=@alia/app",
    "web": "npm run web --workspace=@alia/app"
  },
  "keywords": [
    "monorepo",
    "ai",
    "nextjs",
    "expo",
    "api",
    "alia"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "typescript": "^5.9.3"
  },
  "overrides": {
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-svg": "15.15.3",
    "react-native-worklets": "0.7.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo-secure-store": "55.0.8",
    "react-native-screens": "4.23.0",
    "react-native-gesture-handler": "2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-keyboard-controller": "1.20.7",
    "expo": "55.0.2",
    "expo-blur": "55.0.8",
    "expo-constants": "55.0.7",
    "expo-file-system": "55.0.9",
    "expo-font": "55.0.4",
    "@react-native-menu/menu": "2.0.0"
  },
  "dependencies": {
    "@oxyhq/auth": "^2.0.1",
    "@oxyhq/core": "^1.7.0",
    "@oxyhq/services": "^6.5.0",
    "@types/ws": "^8.18.1",
    "expo-router": "~55.0.2",
    "ws": "^8.19.0"
  }
}
