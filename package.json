{
  "name": "alia-monorepo",
  "version": "1.0.0",
  "description": "Monorepo para Alia - plataforma de IA con app (web+mobile), API y panel admin",
  "private": true,
  "workspaces": [
    "apps/api",
    "apps/app",
    "apps/canvas",
    "apps/telegram-bot",
    "apps/discord-bot",
    "apps/whatsapp-gateway",
    "apps/alia-console",
    "apps/alia-providers-admin",
    "apps/alia-codea",
    "apps/alia-cowork",
    "apps/codea-cli"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "dev:app": "npm run dev --workspace=@alia/app --clear --tunnel",
    "dev:api": "npm run dev --workspace=@alia/api",
    "dev:admin": "npm run dev --workspace=alia-console",
    "dev:canvas": "npm run dev --workspace=alia-canvas",
    "dev:telegram": "npm run dev --workspace=@ai-api-server/telegram-bot",
    "dev:discord": "npm run dev --workspace=@alia/discord-bot",
    "dev:whatsapp": "npm run dev --workspace=@alia/whatsapp-gateway",
    "dev:providers-admin": "npm run dev --workspace=alia-providers-admin",
    "dev:codea": "npm run dev --workspace=alia-codea",
    "dev:cowork": "npm run dev --workspace=alia-cowork",
    "build": "npm run build --workspaces --if-present",
    "build:app": "npm run build --workspace=@alia/app",
    "build:api": "npm run build --workspace=@alia/api",
    "build:admin": "npm run build --workspace=alia-console",
    "build:canvas": "npm run build --workspace=alia-canvas",
    "build:telegram": "npm run build --workspace=@ai-api-server/telegram-bot",
    "build:discord": "npm run build --workspace=@alia/discord-bot",
    "build:whatsapp": "npm run build --workspace=@alia/whatsapp-gateway",
    "start:app": "npm run start --workspace=@alia/app",
    "start:api": "npm run start --workspace=@alia/api",
    "start:admin": "npm run start --workspace=alia-console",
    "start:canvas": "npm run start --workspace=alia-canvas",
    "start:telegram": "npm run start --workspace=@ai-api-server/telegram-bot",
    "start:discord": "npm run start --workspace=@alia/discord-bot",
    "start:whatsapp": "npm run start --workspace=@alia/whatsapp-gateway",
    "lint": "npm run lint --workspaces --if-present",
    "lint:canvas": "npm run lint --workspace=alia-canvas",
    "android": "npm run android --workspace=@alia/app",
    "ios": "npm run ios --workspace=@alia/app",
    "web": "npm run web --workspace=@alia/app"
  },
  "keywords": [
    "monorepo",
    "ai",
    "nextjs",
    "expo",
    "api",
    "alia"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "typescript": "^5.9.3"
  },
  "overrides": {
    "react": "19.2.0",
    "react-dom": "19.2.0"
  },
  "dependencies": {
    "@oxyhq/auth": "^2.0.1",
    "@oxyhq/core": "^1.6.1",
    "@oxyhq/services": "^6.4.0",
    "@types/ws": "^8.18.1",
    "ws": "^8.19.0"
  }
}
